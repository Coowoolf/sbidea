# Copy to .env.local for local development.
# .env.local is gitignored — never commit secrets.

# ------------------------------------------------------------------
# OpenRouter (required)
# ------------------------------------------------------------------
# Get a key from https://openrouter.ai/keys
# We use free models by default so a key alone is enough to run.
OPENROUTER_API_KEY=

# ------------------------------------------------------------------
# Optional
# ------------------------------------------------------------------

# Canonical site URL (used in metadata + as OpenRouter HTTP-Referer header)
NEXT_PUBLIC_SITE_URL=https://sbidea.ai
