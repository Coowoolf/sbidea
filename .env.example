# Copy to .env.local for local development.
# On Vercel production/preview deploys nothing in this file is needed —
# Vercel AI Gateway uses OIDC (VERCEL_OIDC_TOKEN) automatically.

# ------------------------------------------------------------------
# AI provider (choose ONE of the two options below for local dev)
# ------------------------------------------------------------------

# Option A (recommended): Vercel AI Gateway key
# Get it from https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# Option B: Direct Anthropic API key (bypasses the gateway)
# ANTHROPIC_API_KEY=

# ------------------------------------------------------------------
# Optional
# ------------------------------------------------------------------

# Canonical site URL (used in <Metadata> openGraph and canonical tags)
NEXT_PUBLIC_SITE_URL=https://sbidea.ai
